# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

# Logs (large files)
*.jsonl
*.log

# CSVs except logic analyzer captures
*.csv
!src/captures/*.csv

# Editor backups
*~
*.swp
*.swo

# OS files
.DS_Store

# Secrets
.gemini_key
cert.pem
key.pem

# Runtime data
program_history.json
saved_workouts.json
run_history.json
user_profile.json

# C++ build artifacts
*.o
*.d
*.gcda
*.gcno
*.gcov
src/tests/test_*_cov

# Build staging directory
build/

# Rust build artifacts
rust/ftms/target/
rust/hrm/target/
**/target/

# Analysis/experimental scripts (not part of main tools)
analysis/

# Screenshots (dev artifacts, except docs/screenshots which is tracked for README)
screenshots/
!docs/screenshots/

# Three.js (vendored, large)
static/three.module.js

# Node modules
node_modules/

# Gradle build cache (Android)
android/.gradle/
kotlin/.gradle/

# Vite build output (hashed filenames)
static/assets/*.js
static/assets/*.css

# Worktree environment (per-worktree ports)
worktree.env
.worktrees/

# Claude config (local)
.claude/*
!.claude/skills
.claude/skills/*
!.claude/skills/gstack
.gstack/
.superpowers/

# iOS build artifacts
ios/Treddy.xcodeproj/xcuserdata/
ios/DerivedData/
